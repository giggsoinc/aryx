# Aryx — 12-factor configuration. Copy to .env and adjust. NEVER commit .env.
# All app settings are read from ARYX_-prefixed environment variables.

# Canonical relational store (P1: RDB is the source of truth).
ARYX_RDB_DSN=postgresql://aryx:aryx@postgres:5432/aryx

# Derived, rebuildable graph projection.
ARYX_GRAPH_URL=redis://falkordb:6379

ARYX_LOG_LEVEL=INFO
ARYX_BATCH_SIZE=500

# Used only by docker-compose to seed the local postgres container.
POSTGRES_PASSWORD=aryx
