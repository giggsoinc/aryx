# Aryx — 12-factor configuration. Copy to .env and adjust. NEVER commit .env.
# All app settings are read from ARYX_-prefixed environment variables.

# Canonical relational store (P1: RDB is the source of truth).
ARYX_RDB_DSN=postgresql://aryx:aryx@postgres:5432/aryx

# Derived, rebuildable graph projection.
ARYX_GRAPH_URL=redis://falkordb:6379

ARYX_LOG_LEVEL=INFO
ARYX_BATCH_SIZE=500

# LLM runtime (Ask + ingest). Also editable live at /settings in the web UI.
# Keys in Settings stay in process memory; env sets boot defaults.
ARYX_LLM_PROVIDER=ollama
ARYX_LLM_BASE_URL=http://ollama:11434
ARYX_LLM_MENIAL_MODEL=qwen3.5:0.8b
ARYX_LLM_REASON_MODEL=lfm2.5-thinking:latest
ARYX_LLM_API_KEY=
# Examples:
#   ARYX_LLM_PROVIDER=google
#   ARYX_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   ARYX_LLM_PROVIDER=xai
#   ARYX_LLM_BASE_URL=https://api.x.ai/v1

# Used only by docker-compose to seed the local postgres container.
POSTGRES_PASSWORD=aryx
